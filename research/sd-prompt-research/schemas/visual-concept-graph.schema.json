{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.sd-prompt-studio/visual-concept-graph-v0.2.schema.json",
  "title": "SD Prompt Studio Visual Concept Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "graph_version",
    "generated_at",
    "source_files",
    "concepts",
    "relations",
    "target_patterns",
    "unmodeled_effects",
    "model_profiles",
    "intent_profiles",
    "control_context_profiles",
    "indexes"
  ],
  "properties": {
    "schema_version": { "const": "0.2.0" },
    "graph_version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_files": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "concepts": { "type": "array", "items": { "$ref": "#/$defs/concept" } },
    "relations": { "type": "array", "items": { "$ref": "#/$defs/relation" } },
    "target_patterns": { "type": "array", "items": { "$ref": "#/$defs/targetPattern" } },
    "unmodeled_effects": { "type": "array", "items": { "$ref": "#/$defs/unmodeledEffect" } },
    "model_profiles": { "type": "array", "items": { "$ref": "#/$defs/modelProfile" } },
    "intent_profiles": { "type": "array", "items": { "$ref": "#/$defs/intentProfile" } },
    "control_context_profiles": { "type": "array", "items": { "$ref": "#/$defs/controlContextProfile" } },
    "indexes": { "$ref": "#/$defs/indexes" }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["draft", "provisional", "confirmed", "deprecated", "rejected"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high", "unknown"]
    },
    "stability": {
      "type": "string",
      "enum": ["low", "medium", "high", "unknown"]
    },
    "evidenceStatus": {
      "type": "string",
      "enum": ["unconfirmed", "provisional", "confirmed"]
    },
    "module": {
      "type": "string",
      "enum": [
        "physical", "face", "hair", "clothing", "entity_identity",
        "semantic_role", "objects", "environment", "camera", "lighting",
        "effects", "relations"
      ]
    },
    "conceptType": {
      "type": "string",
      "enum": [
        "body_state", "body_orientation", "body_part_configuration", "contact",
        "contact_load", "support_relation", "spatial_relation", "visibility",
        "clothing", "hair", "expression", "gaze", "species", "semantic_role",
        "object", "environment", "camera", "lighting", "effect",
        "unresolved_relational_phrase", "intrinsic_property", "activity"
      ]
    },
    "stringSet": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_ref_id", "run_id", "observation_path", "metric", "confidence", "storage"
      ],
      "dependentRequired": { "count": ["total"], "total": ["count"] },
      "properties": {
        "evidence_ref_id": { "type": "string", "pattern": "^evidence\\.[a-z0-9._-]+$" },
        "run_id": { "type": "string", "minLength": 1 },
        "observation_path": { "type": "string", "minLength": 1 },
        "research_packet_path": { "type": "string", "minLength": 1 },
        "metric": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 },
        "confidence": { "$ref": "#/$defs/confidence" },
        "storage": { "type": "string", "enum": ["local", "external"] },
        "notes": { "$ref": "#/$defs/stringSet" }
      }
    },
    "visibilityRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region", "requirement", "strength"],
      "properties": {
        "region": { "type": "string", "minLength": 1 },
        "requirement": {
          "type": "string",
          "enum": ["required", "preferred", "evidence", "must_be_unobscured"]
        },
        "strength": { "$ref": "#/$defs/confidence" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "modelBehavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_profile_id", "observed_behavior", "status", "evidence_refs"],
      "properties": {
        "model_profile_id": { "type": "string", "minLength": 1 },
        "observed_behavior": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/status" },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidenceRef" } }
      }
    },
    "domainEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "effect", "status", "confidence", "evidence_status"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "effect": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/status" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence_status": { "$ref": "#/$defs/evidenceStatus" },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"evidence_status": {"enum": ["provisional", "confirmed"]}},
            "required": ["evidence_status"]
          },
          "then": {"required": ["evidence_refs"], "properties": {"evidence_refs": {"minItems": 1}}}
        }
      ]
    },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["concept_id", "label", "module", "concept_type", "human_meaning", "status"],
      "properties": {
        "concept_id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$" },
        "label": { "type": "string", "minLength": 1 },
        "aliases": { "$ref": "#/$defs/stringSet" },
        "module": { "$ref": "#/$defs/module" },
        "concept_type": { "$ref": "#/$defs/conceptType" },
        "human_meaning": { "type": "string", "minLength": 1 },
        "observed_model_behavior": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "scope": { "$ref": "#/$defs/stringSet" },
        "state_affinity": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/confidence" }
        },
        "required_constraints": { "$ref": "#/$defs/stringSet" },
        "optional_priors": { "$ref": "#/$defs/stringSet" },
        "conflicts": { "$ref": "#/$defs/stringSet" },
        "visibility_requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/visibilityRequirement" }
        },
        "evidence_regions": { "$ref": "#/$defs/stringSet" },
        "secondary_effects": { "$ref": "#/$defs/stringSet" },
        "stability": { "$ref": "#/$defs/stability" },
        "context_dependency": { "$ref": "#/$defs/confidence" },
        "model_behaviors": { "type": "array", "items": { "$ref": "#/$defs/modelBehavior" } },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidenceRef" } },
        "entity_type": { "type": "string", "enum": ["species"] },
        "morphology_strength": { "type": "string", "enum": ["weak", "moderate", "strong", "transformative"] },
        "role_package": {
          "type": "object",
          "additionalProperties": false,
          "required": ["category"],
          "properties": {
            "category": {
              "type": "string",
              "enum": ["occupation", "rank", "narrative_role", "situational_role", "activity_role"]
            }
          }
        },
        "clothing_properties": {
          "type": "object",
          "additionalProperties": false,
          "required": ["intrinsic", "visibility_effects", "generative_effects"],
          "properties": {
            "intrinsic": {
              "type": "object",
              "additionalProperties": false,
              "required": ["garment_type"],
              "properties": {
                "garment_type": { "type": "string", "minLength": 1 },
                "fit": { "type": "string", "minLength": 1 },
                "length": { "type": "string", "minLength": 1 },
                "material_behavior": { "$ref": "#/$defs/stringSet" },
                "covered_regions": { "$ref": "#/$defs/stringSet" }
              }
            },
            "visibility_effects": { "type": "array", "items": { "$ref": "#/$defs/domainEffect" } },
            "generative_effects": { "type": "array", "items": { "$ref": "#/$defs/domainEffect" } }
          }
        },
        "hair_properties": {
          "type": "object",
          "additionalProperties": false,
          "required": ["intrinsic", "visibility_effects", "generative_effects"],
          "properties": {
            "intrinsic": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "length": { "type": "string", "minLength": 1 },
                "style": { "type": "string", "minLength": 1 },
                "material_behavior": { "$ref": "#/$defs/stringSet" },
                "covered_regions": { "$ref": "#/$defs/stringSet" }
              }
            },
            "visibility_effects": { "type": "array", "items": { "$ref": "#/$defs/domainEffect" } },
            "generative_effects": { "type": "array", "items": { "$ref": "#/$defs/domainEffect" } }
          }
        },
        "status": { "$ref": "#/$defs/status" },
        "notes": { "$ref": "#/$defs/stringSet" }
      },
      "allOf": [
        {
          "if": { "properties": { "concept_type": { "const": "species" } }, "required": ["concept_type"] },
          "then": {
            "required": ["entity_type", "morphology_strength", "required_constraints", "optional_priors", "visibility_requirements"]
          }
        },
        {
          "if": { "properties": { "concept_type": { "const": "semantic_role" } }, "required": ["concept_type"] },
          "then": { "required": ["role_package"] }
        },
        {
          "if": { "properties": { "concept_type": { "const": "clothing" } }, "required": ["concept_type"] },
          "then": { "required": ["clothing_properties"] }
        },
        {
          "if": { "properties": { "concept_type": { "const": "hair" } }, "required": ["concept_type"] },
          "then": { "required": ["hair_properties"] }
        },
        {
          "if": { "properties": { "concept_type": { "const": "unresolved_relational_phrase" } }, "required": ["concept_type"] },
          "then": { "required": ["stability"] }
        }
      ]
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_id", "relation_type", "source_concept_id", "target_concept_id",
        "direction", "strength", "confidence", "status"
      ],
      "properties": {
        "relation_id": { "type": "string", "pattern": "^relation\\.[a-z0-9._-]+$" },
        "relation_type": {
          "type": "string",
          "enum": [
            "supports", "contacts", "positioned_relative_to", "covers", "obscures",
            "increases_visibility", "decreases_visibility", "biases", "strengthens",
            "weakens", "conflicts_with", "requires", "implies", "may_trigger",
            "observed_as", "candidate_interpretation"
          ]
        },
        "source_concept_id": { "type": "string", "minLength": 1 },
        "target_concept_id": { "type": "string", "minLength": 1 },
        "direction": { "type": "string", "enum": ["directed", "symmetric"] },
        "strength": { "$ref": "#/$defs/confidence" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "context": { "type": "string", "minLength": 1 },
        "model_profile": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidenceRef" } },
        "status": { "$ref": "#/$defs/status" },
        "notes": { "$ref": "#/$defs/stringSet" }
      }
    },
    "targetPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_pattern_id", "label", "human_intent_names", "required_constraints",
        "preferred_constraints", "conflicts", "evidence_requirements", "status"
      ],
      "properties": {
        "target_pattern_id": { "type": "string", "pattern": "^pattern\\.[a-z0-9._-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "human_intent_names": { "$ref": "#/$defs/stringSet" },
        "required_constraints": { "$ref": "#/$defs/stringSet" },
        "preferred_constraints": { "$ref": "#/$defs/stringSet" },
        "conflicts": { "$ref": "#/$defs/stringSet" },
        "evidence_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/visibilityRequirement" }
        },
        "candidate_alternatives": { "$ref": "#/$defs/stringSet" },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidenceRef" } },
        "status": { "$ref": "#/$defs/status" },
        "notes": { "$ref": "#/$defs/stringSet" }
      }
    },
    "unmodeledEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect_id", "category", "observed_effect", "confidence", "evidence_refs", "promotion_status"
      ],
      "properties": {
        "effect_id": { "type": "string", "pattern": "^unmodeled\\.[a-z0-9._-]+$" },
        "category": {
          "type": "string",
          "enum": ["unknown", "unmodeled", "rare_variant", "model_specific", "ambiguous_mapping", "cross_domain_effect"]
        },
        "source_phrase": { "type": "string", "minLength": 1 },
        "source_concept_id": { "type": "string", "minLength": 1 },
        "target_module": { "$ref": "#/$defs/module" },
        "target_region": { "type": "string", "minLength": 1 },
        "observed_effect": { "type": "string", "minLength": 1 },
        "evidence_region": { "type": "string", "minLength": 1 },
        "frequency": { "type": "string", "pattern": "^[0-9]+/[0-9]+$" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "candidate_axis": { "type": "string", "minLength": 1 },
        "model_profile": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidenceRef" } },
        "promotion_status": { "type": "string", "enum": ["observed", "candidate", "nominated", "promoted", "rejected"] },
        "promotion_criteria": { "$ref": "#/$defs/stringSet" },
        "notes": { "$ref": "#/$defs/stringSet" }
      }
    },
    "modelProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_profile_id", "label", "status"],
      "properties": {
        "model_profile_id": { "type": "string", "pattern": "^model\\.[a-z0-9._-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "checkpoint": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/status" },
        "notes": { "$ref": "#/$defs/stringSet" }
      }
    },
    "intentProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent_profile_id", "human_intent_names", "required_structural_concepts",
        "preferred_structural_concepts", "conflict_concepts", "visibility_requirements",
        "target_pattern_ids", "status"
      ],
      "properties": {
        "intent_profile_id": { "type": "string", "pattern": "^intent\\.[a-z0-9._-]+$" },
        "human_intent_names": { "$ref": "#/$defs/stringSet" },
        "required_structural_concepts": { "$ref": "#/$defs/stringSet" },
        "preferred_structural_concepts": { "$ref": "#/$defs/stringSet" },
        "conflict_concepts": { "$ref": "#/$defs/stringSet" },
        "visibility_requirements": { "type": "array", "items": { "$ref": "#/$defs/visibilityRequirement" } },
        "target_pattern_ids": { "$ref": "#/$defs/stringSet" },
        "status": { "$ref": "#/$defs/status" },
        "notes": { "$ref": "#/$defs/stringSet" }
      }
    },
    "controlContextProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_profile_id", "label", "profile_type", "fixed_phrases",
        "fixed_concept_ids", "known_visibility_risks", "status"
      ],
      "properties": {
        "context_profile_id": { "type": "string", "pattern": "^context\\.[a-z0-9._-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "profile_type": { "type": "string", "enum": ["control_baseline", "generation_context"] },
        "fixed_phrases": { "$ref": "#/$defs/stringSet" },
        "fixed_concept_ids": { "$ref": "#/$defs/stringSet" },
        "known_visibility_risks": { "type": "array", "items": { "$ref": "#/$defs/domainEffect" } },
        "status": { "$ref": "#/$defs/status" },
        "notes": { "$ref": "#/$defs/stringSet" }
      }
    },
    "sourceModule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "graph_version", "module_file_id", "module_family"],
      "properties": {
        "schema_version": { "const": "0.2.0" },
        "graph_version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$" },
        "module_file_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "module_family": {
          "type": "string",
          "enum": ["physical", "semantic", "relations", "target_patterns", "unmodeled_effects"]
        },
        "description": { "type": "string", "minLength": 1 },
        "concepts": { "type": "array", "items": { "$ref": "#/$defs/concept" } },
        "relations": { "type": "array", "items": { "$ref": "#/$defs/relation" } },
        "target_patterns": { "type": "array", "items": { "$ref": "#/$defs/targetPattern" } },
        "unmodeled_effects": { "type": "array", "items": { "$ref": "#/$defs/unmodeledEffect" } },
        "model_profiles": { "type": "array", "items": { "$ref": "#/$defs/modelProfile" } },
        "intent_profiles": { "type": "array", "items": { "$ref": "#/$defs/intentProfile" } },
        "control_context_profiles": { "type": "array", "items": { "$ref": "#/$defs/controlContextProfile" } }
      }
    },
    "idArrayIndex": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/stringSet" }
    },
    "indexes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "concepts_by_id", "concepts_by_module", "concepts_by_type", "aliases_to_concept_id",
        "relations_by_source", "relations_by_target", "target_patterns_by_id",
        "intent_profiles_by_id", "control_context_profiles_by_id", "evidence_by_run_id"
      ],
      "properties": {
        "concepts_by_id": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "concepts_by_module": { "$ref": "#/$defs/idArrayIndex" },
        "concepts_by_type": { "$ref": "#/$defs/idArrayIndex" },
        "aliases_to_concept_id": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 } },
        "relations_by_source": { "$ref": "#/$defs/idArrayIndex" },
        "relations_by_target": { "$ref": "#/$defs/idArrayIndex" },
        "target_patterns_by_id": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "intent_profiles_by_id": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "control_context_profiles_by_id": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "evidence_by_run_id": { "$ref": "#/$defs/idArrayIndex" }
      }
    }
  }
}
