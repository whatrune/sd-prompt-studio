{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.sd-prompt-studio/research-claim-assertion-v0.1.schema.json",
  "title": "SD Prompt Studio Research Claim Assertion File",
  "description": "Research Claim Staging Layer v3.9.31 Freeze. Assertions stage research claims and are not Visual Concept Graph source objects.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assertion_file_id",
    "claim_family",
    "path_base",
    "metric_path_syntax",
    "axis_registry_refs",
    "evidence_refs",
    "assertions"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "assertion_file_id": { "$ref": "#/$defs/fileId" },
    "claim_family": { "$ref": "#/$defs/snakeName" },
    "path_base": { "const": "research_project_root" },
    "metric_path_syntax": { "const": "dotted_object_path_v1" },
    "axis_registry_refs": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/snakeName" },
      "additionalProperties": { "$ref": "#/$defs/axisRegistryRef" }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidenceFact" }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/assertion" }
    }
  },
  "$defs": {
    "fileId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "snakeName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "stableDotId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*)+$"
    },
    "assertionId": {
      "type": "string",
      "pattern": "^assertion(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){2,}\\.[0-9]{3,}$"
    },
    "evidenceId": {
      "type": "string",
      "pattern": "^evidence(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){3,}$"
    },
    "interpretationId": {
      "type": "string",
      "pattern": "^interpretation(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){2,}\\.[0-9]{3,}$"
    },
    "causalHypothesisId": {
      "type": "string",
      "pattern": "^causal_hypothesis(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){2,}\\.[0-9]{3,}$"
    },
    "reviewId": {
      "type": "string",
      "pattern": "^review\\.assertion(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){2,}\\.[0-9]{3,}\\.[0-9]{3,}$"
    },
    "approvalId": {
      "type": "string",
      "pattern": "^promotion_approval\\.assertion(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){2,}\\.[0-9]{3,}\\.[0-9]{3,}$"
    },
    "applicationId": {
      "type": "string",
      "pattern": "^application\\.assertion(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){2,}\\.[0-9]{3,}\\.[0-9]{3,}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "repositoryPath": {
      "type": "string",
      "pattern": "^research/sd-prompt-research/(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[^:\\r\\n]+$"
    },
    "researchProjectPath": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!//)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[^:\\r\\n]+$"
    },
    "metricPath": {
      "type": "string",
      "pattern": "^[a-z0-9_]+(?:\\.[a-z0-9_]+)*$"
    },
    "stringSet": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "nonEmptyStringSet": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "axisRegistryRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/researchProjectPath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "measurementCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level"],
      "properties": {
        "level": { "enum": ["full", "partial", "limited"] }
      }
    },
    "evidenceFact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_ref_id",
        "observation_module",
        "observation_path",
        "metric",
        "denominator_path",
        "count",
        "total",
        "storage",
        "measurement_coverage"
      ],
      "properties": {
        "evidence_ref_id": { "$ref": "#/$defs/evidenceId" },
        "observation_module": {
          "enum": ["pose", "face", "hair", "clothing", "camera", "object", "other"]
        },
        "observation_path": { "$ref": "#/$defs/repositoryPath" },
        "metric": { "$ref": "#/$defs/metricPath" },
        "denominator_path": { "$ref": "#/$defs/metricPath" },
        "count": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 },
        "storage": { "const": "local" },
        "measurement_coverage": { "$ref": "#/$defs/measurementCoverage" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "conceptSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "concept_id"],
      "properties": {
        "kind": { "const": "concept_ref" },
        "concept_id": { "$ref": "#/$defs/stableDotId" },
        "source_phrase": { "type": "string", "minLength": 1 }
      }
    },
    "phraseSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "phrase", "locale", "normalized_phrase"],
      "properties": {
        "kind": { "const": "phrase_surface" },
        "phrase": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$" },
        "normalized_phrase": { "type": "string", "minLength": 1 }
      }
    },
    "subject": {
      "oneOf": [
        { "$ref": "#/$defs/conceptSubject" },
        { "$ref": "#/$defs/phraseSubject" }
      ]
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 }
      }
    },
    "observedMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "count", "total", "evidence_ref_ids"],
      "properties": {
        "metric": { "$ref": "#/$defs/metricPath" },
        "count": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 },
        "evidence_ref_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceId" }
        }
      }
    },
    "interpretationCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interpretation_candidate_id", "label"],
      "properties": {
        "interpretation_candidate_id": { "$ref": "#/$defs/interpretationId" },
        "label": { "$ref": "#/$defs/snakeName" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "targetAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "registration_status"],
      "properties": {
        "name": { "$ref": "#/$defs/snakeName" },
        "registration_status": { "enum": ["registered", "proposed"] }
      }
    },
    "causalHypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["causal_hypothesis_id", "source", "relation_type", "target_module"],
      "properties": {
        "causal_hypothesis_id": { "$ref": "#/$defs/causalHypothesisId" },
        "source": { "$ref": "#/$defs/stableDotId" },
        "relation_type": { "$ref": "#/$defs/snakeName" },
        "target_module": {
          "enum": ["pose", "face", "hair", "clothing", "camera", "object", "other"]
        },
        "target_axis": { "$ref": "#/$defs/targetAxis" },
        "target_concept_id": { "$ref": "#/$defs/stableDotId" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "referenceId": {
      "oneOf": [
        { "$ref": "#/$defs/assertionId" },
        { "$ref": "#/$defs/interpretationId" },
        { "$ref": "#/$defs/causalHypothesisId" }
      ]
    },
    "evidenceQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coverage", "directness", "consistency"],
      "properties": {
        "coverage": { "enum": ["full", "partial", "limited"] },
        "directness": { "enum": ["direct", "indirect"] },
        "consistency": { "enum": ["high", "medium", "low"] }
      }
    },
    "evidenceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_ref_id", "evidence_role", "applies_to", "evidence_quality"],
      "properties": {
        "evidence_ref_id": { "$ref": "#/$defs/evidenceId" },
        "evidence_role": { "enum": ["supports", "contradicts", "context_only", "inconclusive"] },
        "applies_to": { "$ref": "#/$defs/referenceId" },
        "evidence_quality": { "$ref": "#/$defs/evidenceQuality" },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "reproduction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "panel_count", "condition_count", "condition_ids", "run_count", "run_ids",
        "independent_experiment_count", "experiment_group_ids", "model_count", "model_ids",
        "context_count", "context_ids"
      ],
      "properties": {
        "panel_count": { "type": "integer", "minimum": 1 },
        "condition_count": { "type": "integer", "minimum": 1 },
        "condition_ids": { "$ref": "#/$defs/nonEmptyStringSet" },
        "run_count": { "type": "integer", "minimum": 1 },
        "run_ids": { "$ref": "#/$defs/nonEmptyStringSet" },
        "independent_experiment_count": { "type": "integer", "minimum": 1 },
        "experiment_group_ids": { "$ref": "#/$defs/nonEmptyStringSet" },
        "model_count": { "type": "integer", "minimum": 1 },
        "model_ids": { "$ref": "#/$defs/nonEmptyStringSet" },
        "context_count": { "type": "integer", "minimum": 1 },
        "context_ids": { "$ref": "#/$defs/nonEmptyStringSet" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_scope", "context_scope", "domain_scope", "generalization_scope"],
      "properties": {
        "model_scope": { "enum": ["single_model", "multi_model", "unknown"] },
        "context_scope": { "enum": ["single_context", "multi_context", "unknown"] },
        "domain_scope": { "enum": ["pose", "face", "clothing", "hair", "object", "other"] },
        "generalization_scope": { "enum": ["local", "provisional_general", "general"] }
      }
    },
    "generalizationStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_dependency_tested", "context_dependency_tested"],
      "properties": {
        "model_dependency_tested": { "type": "boolean" },
        "context_dependency_tested": { "type": "boolean" }
      }
    },
    "createdBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "version", "created_at"],
      "properties": {
        "agent": { "enum": ["research_ai", "human", "codex"] },
        "version": { "type": "string", "minLength": 1 },
        "created_at": { "$ref": "#/$defs/timestamp" }
      }
    },
    "promotionStatus": {
      "enum": ["not_nominated", "nominated", "approved", "applied", "rejected"]
    },
    "promotionCommon": {
      "type": "object",
      "properties": {
        "status": { "$ref": "#/$defs/promotionStatus" },
        "approval_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/approvalId" }
        },
        "applications": {
          "type": "array",
          "items": { "$ref": "#/$defs/application" }
        }
      }
    },
    "attachPromotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "status", "target_id", "approval_ids", "applications"],
      "properties": {
        "action": { "enum": ["add_alias", "attach_model_behavior", "attach_evidence"] },
        "status": { "$ref": "#/$defs/promotionStatus" },
        "target_id": { "$ref": "#/$defs/stableDotId" },
        "approval_ids": {
          "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/approvalId" }
        },
        "applications": { "type": "array", "items": { "$ref": "#/$defs/application" } }
      }
    },
    "createPromotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "status", "approval_ids", "applications"],
      "properties": {
        "action": { "enum": ["create_relation", "create_concept", "create_target_pattern"] },
        "status": { "$ref": "#/$defs/promotionStatus" },
        "proposed_id": { "$ref": "#/$defs/stableDotId" },
        "approval_ids": {
          "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/approvalId" }
        },
        "applications": { "type": "array", "items": { "$ref": "#/$defs/application" } }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "enum": ["nominated", "approved", "applied", "rejected"] } },
            "required": ["status"]
          },
          "then": { "required": ["proposed_id"] }
        }
      ]
    },
    "nonPromotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "status", "approval_ids", "applications"],
      "properties": {
        "action": { "enum": ["retain_unmodeled", "no_promotion"] },
        "status": { "const": "not_nominated" },
        "approval_ids": { "type": "array", "maxItems": 0 },
        "applications": { "type": "array", "maxItems": 0 }
      }
    },
    "promotion": {
      "oneOf": [
        { "$ref": "#/$defs/attachPromotion" },
        { "$ref": "#/$defs/createPromotion" },
        { "$ref": "#/$defs/nonPromotion" }
      ]
    },
    "createPromotionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "proposed_id", "assertion_hash"],
      "properties": {
        "action": { "enum": ["create_relation", "create_concept", "create_target_pattern"] },
        "proposed_id": { "$ref": "#/$defs/stableDotId" },
        "assertion_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "attachPromotionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "target_id", "assertion_hash"],
      "properties": {
        "action": { "enum": ["add_alias", "attach_model_behavior", "attach_evidence"] },
        "target_id": { "$ref": "#/$defs/stableDotId" },
        "assertion_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "contentLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "field_path", "item_key"],
      "properties": {
        "target_id": { "$ref": "#/$defs/stableDotId" },
        "field_path": { "type": "string", "pattern": "^/(?:[^/~]|~[01])+(?:/(?:[^/~]|~[01])+)*$" },
        "item_key": { "type": "string", "minLength": 1 }
      }
    },
    "createAppliedContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_kind", "collection", "content_hash", "hash_algorithm", "hash_scope"],
      "properties": {
        "content_kind": { "enum": ["concept", "relation", "target_pattern"] },
        "collection": { "enum": ["concepts", "relations", "target_patterns"] },
        "content_hash": { "$ref": "#/$defs/sha256" },
        "hash_algorithm": { "const": "sha256" },
        "hash_scope": { "const": "graph_content_v1" }
      }
    },
    "attachAppliedContent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_kind", "collection", "content_locator", "content_hash", "hash_algorithm", "hash_scope"
      ],
      "properties": {
        "content_kind": { "enum": ["alias", "model_behavior", "evidence_ref"] },
        "collection": { "const": "concepts" },
        "content_locator": { "$ref": "#/$defs/contentLocator" },
        "content_hash": { "$ref": "#/$defs/sha256" },
        "hash_algorithm": { "const": "sha256" },
        "hash_scope": { "const": "graph_content_v1" }
      }
    },
    "applicationCommonProperties": {
      "type": "object",
      "properties": {
        "application_id": { "$ref": "#/$defs/applicationId" },
        "assertion_id": { "$ref": "#/$defs/assertionId" },
        "claim_review_ids": {
          "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/reviewId" }
        },
        "promotion_approval_id": { "$ref": "#/$defs/approvalId" },
        "applied_assertion_hash": { "$ref": "#/$defs/sha256" },
        "applied_promotion_hash": { "$ref": "#/$defs/sha256" },
        "applied_graph_version": { "$ref": "#/$defs/semver" },
        "applied_at": { "$ref": "#/$defs/timestamp" },
        "recorded_at": { "$ref": "#/$defs/timestamp" },
        "supersedes_application_ids": {
          "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/applicationId" }
        }
      }
    },
    "createApplication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "application_id", "assertion_id", "claim_review_ids", "promotion_approval_id",
        "applied_promotion_plan", "applied_assertion_hash", "applied_promotion_hash",
        "applied_content", "applied_graph_version", "applied_at", "recorded_at",
        "supersedes_application_ids", "created_id"
      ],
      "properties": {
        "application_id": { "$ref": "#/$defs/applicationId" },
        "assertion_id": { "$ref": "#/$defs/assertionId" },
        "claim_review_ids": {
          "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/reviewId" }
        },
        "promotion_approval_id": { "$ref": "#/$defs/approvalId" },
        "applied_promotion_plan": { "$ref": "#/$defs/createPromotionPlan" },
        "applied_assertion_hash": { "$ref": "#/$defs/sha256" },
        "applied_promotion_hash": { "$ref": "#/$defs/sha256" },
        "applied_content": { "$ref": "#/$defs/createAppliedContent" },
        "applied_graph_version": { "$ref": "#/$defs/semver" },
        "applied_at": { "$ref": "#/$defs/timestamp" },
        "recorded_at": { "$ref": "#/$defs/timestamp" },
        "supersedes_application_ids": {
          "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/applicationId" }
        },
        "created_id": { "$ref": "#/$defs/stableDotId" }
      }
    },
    "attachApplication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "application_id", "assertion_id", "claim_review_ids", "promotion_approval_id",
        "applied_promotion_plan", "applied_assertion_hash", "applied_promotion_hash",
        "applied_content", "applied_graph_version", "applied_at", "recorded_at",
        "supersedes_application_ids", "applied_target_id"
      ],
      "properties": {
        "application_id": { "$ref": "#/$defs/applicationId" },
        "assertion_id": { "$ref": "#/$defs/assertionId" },
        "claim_review_ids": {
          "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/reviewId" }
        },
        "promotion_approval_id": { "$ref": "#/$defs/approvalId" },
        "applied_promotion_plan": { "$ref": "#/$defs/attachPromotionPlan" },
        "applied_assertion_hash": { "$ref": "#/$defs/sha256" },
        "applied_promotion_hash": { "$ref": "#/$defs/sha256" },
        "applied_content": { "$ref": "#/$defs/attachAppliedContent" },
        "applied_graph_version": { "$ref": "#/$defs/semver" },
        "applied_at": { "$ref": "#/$defs/timestamp" },
        "recorded_at": { "$ref": "#/$defs/timestamp" },
        "supersedes_application_ids": {
          "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/applicationId" }
        },
        "applied_target_id": { "$ref": "#/$defs/stableDotId" }
      }
    },
    "application": {
      "oneOf": [
        { "$ref": "#/$defs/createApplication" },
        { "$ref": "#/$defs/attachApplication" }
      ]
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertion_id", "status", "subject", "claim", "observed_metrics",
        "interpretation_candidates", "causal_hypotheses", "evidence_bindings",
        "depends_on", "supersedes", "reproduction", "scope", "generalization_status",
        "created_by", "promotion"
      ],
      "properties": {
        "assertion_id": { "$ref": "#/$defs/assertionId" },
        "status": { "enum": ["draft", "provisional", "confirmed", "rejected", "superseded", "deprecated"] },
        "subject": { "$ref": "#/$defs/subject" },
        "claim": { "$ref": "#/$defs/claim" },
        "observed_metrics": { "type": "array", "items": { "$ref": "#/$defs/observedMetric" } },
        "interpretation_candidates": { "type": "array", "items": { "$ref": "#/$defs/interpretationCandidate" } },
        "causal_hypotheses": { "type": "array", "items": { "$ref": "#/$defs/causalHypothesis" } },
        "evidence_bindings": { "type": "array", "items": { "$ref": "#/$defs/evidenceBinding" } },
        "depends_on": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/assertionId" } },
        "supersedes": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/assertionId" } },
        "reproduction": { "$ref": "#/$defs/reproduction" },
        "scope": { "$ref": "#/$defs/scope" },
        "generalization_status": { "$ref": "#/$defs/generalizationStatus" },
        "created_by": { "$ref": "#/$defs/createdBy" },
        "promotion": { "$ref": "#/$defs/promotion" },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
