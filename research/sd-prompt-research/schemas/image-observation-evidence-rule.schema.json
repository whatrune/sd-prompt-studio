{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.sd-prompt-studio/image-observation-evidence-rule-v0.1.schema.json",
  "x-contract-version": "0.1.0",
  "title": "SD Prompt Studio Image Observation Evidence Rule Set",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "rule_set_id", "target_contracts", "rules"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "rule_set_id": {"$ref": "#/$defs/ruleSetId"},
    "target_contracts": {"$ref": "#/$defs/targetContracts"},
    "rules": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/rule"}
    }
  },
  "$defs": {
    "ruleSetId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "ruleId": {
      "type": "string",
      "pattern": "^evidence_rule\\.[a-z][a-z0-9]*(?:\\.[a-z0-9_]+)*$"
    },
    "snakeCase": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "rubricPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!//)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\\\r\\n]+$"
    },
    "targetContracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation_module",
        "observation_schema_version",
        "camera_visibility_metadata_schema_version"
      ],
      "properties": {
        "observation_module": {"const": "pose"},
        "observation_schema_version": {"const": "3.0"},
        "camera_visibility_metadata_schema_version": {"const": "0.1.0"}
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "axis_ref",
        "rubric_ref",
        "visibility_prerequisite",
        "observation_values_requiring_prerequisite",
        "insufficient_visibility_policy"
      ],
      "properties": {
        "rule_id": {"$ref": "#/$defs/ruleId"},
        "axis_ref": {"$ref": "#/$defs/axisRef"},
        "rubric_ref": {"$ref": "#/$defs/rubricRef"},
        "visibility_prerequisite": {"$ref": "#/$defs/visibilityPrerequisite"},
        "observation_values_requiring_prerequisite": {
          "$ref": "#/$defs/observationValues"
        },
        "insufficient_visibility_policy": {
          "$ref": "#/$defs/insufficientVisibilityPolicy"
        }
      }
    },
    "axisRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observation_module", "axis_name"],
      "properties": {
        "observation_module": {"const": "pose"},
        "axis_name": {"$ref": "#/$defs/snakeCase"}
      }
    },
    "rubricRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rubric_path", "rubric_hash_contract", "rubric_sha256"],
      "properties": {
        "rubric_path": {"$ref": "#/$defs/rubricPath"},
        "rubric_hash_contract": {"const": "normalized_text_file_sha256_v1"},
        "rubric_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "visibilityPrerequisite": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "all_of": {"$ref": "#/$defs/conditions"},
        "any_of": {"$ref": "#/$defs/conditions"}
      },
      "oneOf": [
        {
          "required": ["all_of"],
          "not": {"required": ["any_of"]}
        },
        {
          "required": ["any_of"],
          "not": {"required": ["all_of"]}
        }
      ]
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/condition"}
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region", "allowed_states"],
      "properties": {
        "region": {"$ref": "#/$defs/region"},
        "allowed_states": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/visibilityState"}
        }
      }
    },
    "region": {
      "enum": [
        "head", "face", "hair", "neck", "shoulders", "arms",
        "hands", "torso", "hips", "legs", "knees", "feet"
      ]
    },
    "visibilityState": {
      "enum": ["visible", "partial", "unclear", "not_visible"]
    },
    "observationValues": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/snakeCase"}
    },
    "insufficientVisibilityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_fallback_values"],
      "properties": {
        "allowed_fallback_values": {"$ref": "#/$defs/observationValues"}
      }
    }
  }
}
