{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.sd-prompt-studio/observation-to-claim-draft-v0.1.schema.json",
  "x-contract-version": "0.1.0",
  "title": "SD Prompt Studio Pre-schema Claim Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draft_schema_version", "draft_type", "generator_contract", "generator_version",
    "template_version", "draft_id", "draft_input_identity_hash", "draft_input_identity",
    "run_metadata", "observation_statements", "staged_evidence",
    "used_module_compatibility", "used_metric_compatibility", "unresolved_fields",
    "human_decision_required"
  ],
  "properties": {
    "draft_schema_version": {"const": "0.1.0"},
    "draft_type": {"const": "descriptive_observation"},
    "generator_contract": {"const": "observation_to_claim_draft_v1"},
    "generator_version": {"$ref": "#/$defs/semver"},
    "template_version": {"type": "string", "minLength": 1},
    "draft_id": {"type": "string", "pattern": "^draft\\.[a-f0-9]{64}$"},
    "draft_input_identity_hash": {"$ref": "#/$defs/sha256"},
    "draft_input_identity": {"$ref": "#/$defs/draftInputIdentity"},
    "run_metadata": {"type": "array", "items": {"$ref": "#/$defs/runMetadata"}},
    "observation_statements": {"type": "array", "items": {"$ref": "#/$defs/extractedMetric"}},
    "staged_evidence": {"type": "array", "items": {"$ref": "#/$defs/stagedEvidence"}},
    "used_module_compatibility": {"type": "array", "items": {"$ref": "#/$defs/moduleCompatibility"}},
    "used_metric_compatibility": {"type": "array", "items": {"$ref": "#/$defs/metricCompatibility"}},
    "unresolved_fields": {"type": "array", "items": {"$ref": "#/$defs/unresolvedField"}},
    "human_decision_required": {"type": "array", "items": {"$ref": "#/$defs/humanDecision"}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "semver": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"},
    "sourceFile": {
      "type": "object", "additionalProperties": false,
      "required": ["source_role", "logical_path", "hash_algorithm", "hash_value", "parse_status", "module", "run_id"],
      "properties": {
        "source_role": {"enum": ["observation", "optional_module_observation", "manifest", "experiment_group_metadata", "module_registry", "axis_registry", "rubric"]},
        "logical_path": {"type": "string", "minLength": 1},
        "hash_algorithm": {"enum": ["jcs_sha256_v1", "normalized_text_file_sha256_v1", "raw_bytes_sha256_v1"]},
        "hash_value": {"$ref": "#/$defs/sha256"},
        "parse_status": {"enum": ["succeeded", "failed"]},
        "module": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1}
      }
    },
    "draftInputIdentity": {
      "type": "object", "additionalProperties": false,
      "required": [
        "source_files", "observation_validator_version", "aggregate_consistency_profile_version",
        "metric_extraction_profile_version", "generator_contract", "generator_version", "template_version",
        "registry_schema_version", "registry_version", "registry_content_hash",
        "used_module_compatibility", "used_metric_compatibility", "evidence_id_contract_version",
        "draft_schema_version"
      ],
      "properties": {
        "source_files": {"type": "array", "items": {"$ref": "#/$defs/sourceFile"}},
        "observation_validator_version": {"type": "string", "minLength": 1},
        "aggregate_consistency_profile_version": {"type": "string", "minLength": 1},
        "metric_extraction_profile_version": {"type": "string", "minLength": 1},
        "generator_contract": {"const": "observation_to_claim_draft_v1"},
        "generator_version": {"$ref": "#/$defs/semver"},
        "template_version": {"type": "string", "minLength": 1},
        "registry_schema_version": {"type": "string", "minLength": 1},
        "registry_version": {"type": "string", "minLength": 1},
        "registry_content_hash": {"$ref": "#/$defs/sha256"},
        "used_module_compatibility": {"type": "array", "items": {"$ref": "#/$defs/moduleCompatibility"}},
        "used_metric_compatibility": {"type": "array", "items": {"$ref": "#/$defs/metricCompatibility"}},
        "evidence_id_contract_version": {"const": "evidence_id_v1"},
        "draft_schema_version": {"const": "0.1.0"}
      }
    },
    "runMetadata": {
      "type": "object", "additionalProperties": false,
      "required": ["run_id", "condition_id", "panel_count", "experiment_group_id", "model_id", "context_id"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "condition_id": {"type": "string", "minLength": 1},
        "panel_count": {"type": "integer", "minimum": 1},
        "experiment_group_id": {"type": "string", "minLength": 1},
        "model_id": {"type": "string", "minLength": 1},
        "context_id": {"type": "string", "minLength": 1}
      }
    },
    "extractedMetric": {
      "type": "object", "additionalProperties": false,
      "required": ["module", "metric_path", "observed_value", "count", "total", "evidence_candidate_id"],
      "properties": {
        "module": {"type": "string", "minLength": 1},
        "metric_path": {"type": "string", "pattern": "^[a-z0-9_]+(?:\\.[a-z0-9_]+)*$"},
        "observed_value": {"type": "string", "minLength": 1},
        "count": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 1},
        "evidence_candidate_id": {"type": "string", "minLength": 1}
      }
    },
    "stagedEvidence": {
      "type": "object", "additionalProperties": false,
      "required": [
        "evidence_candidate_id", "evidence_id", "evidence_id_contract_version",
        "evidence_id_projection", "evidence_id_projection_hash", "observation_content_hash",
        "evidence_content_hash", "canonical_fact"
      ],
      "properties": {
        "evidence_candidate_id": {"type": "string", "minLength": 1},
        "evidence_id": {"type": "string", "minLength": 1},
        "evidence_id_contract_version": {"const": "evidence_id_v1"},
        "evidence_id_projection": {"$ref": "#/$defs/evidenceIdProjection"},
        "evidence_id_projection_hash": {"$ref": "#/$defs/sha256"},
        "observation_content_hash": {"$ref": "#/$defs/sha256"},
        "evidence_content_hash": {"$ref": "#/$defs/sha256"},
        "canonical_fact": {"$ref": "https://local.sd-prompt-studio/research-claim-assertion-v0.1.schema.json#/$defs/evidenceFact"}
      }
    },
    "evidenceIdProjection": {
      "type": "object", "additionalProperties": false,
      "required": ["normalized_run_id", "canonical_module_slug", "metric_slug", "source_hash_prefix"],
      "properties": {
        "normalized_run_id": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"},
        "canonical_module_slug": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"},
        "metric_slug": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"},
        "source_hash_prefix": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "moduleCompatibility": {
      "type": "object", "additionalProperties": false,
      "required": [
        "canonical_module_slug", "semantic_contract_version", "evidence_id_contract",
        "module_hard_compatibility_hash", "module_change_fingerprint_hash", "status_at_generation"
      ],
      "properties": {
        "canonical_module_slug": {"type": "string", "minLength": 1},
        "semantic_contract_version": {"type": "string", "minLength": 1},
        "evidence_id_contract": {"const": "evidence_id_v1"},
        "module_hard_compatibility_hash": {"$ref": "#/$defs/sha256"},
        "module_change_fingerprint_hash": {"$ref": "#/$defs/sha256"},
        "status_at_generation": {"enum": ["active", "deprecated"]}
      }
    },
    "metricCompatibility": {
      "type": "object", "additionalProperties": false,
      "required": ["module", "registry_role", "metric", "compatibility_projection_version", "compatibility_hash"],
      "properties": {
        "module": {"type": "string", "minLength": 1},
        "registry_role": {"type": "string", "minLength": 1},
        "metric": {"type": "string", "minLength": 1},
        "compatibility_projection_version": {"const": "metric_compatibility_v1"},
        "compatibility_hash": {"$ref": "#/$defs/sha256"}
      }
    },
    "unresolvedField": {
      "type": "object", "additionalProperties": false,
      "required": ["field_path", "reason_code"],
      "properties": {
        "field_path": {"type": "string", "minLength": 1},
        "reason_code": {"type": "string", "minLength": 1}
      }
    },
    "humanDecision": {
      "type": "object", "additionalProperties": false,
      "required": ["decision_key", "reason_code", "candidate_ids"],
      "properties": {
        "decision_key": {"type": "string", "minLength": 1},
        "reason_code": {"type": "string", "minLength": 1},
        "candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
