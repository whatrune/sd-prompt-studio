{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.sd-prompt-studio/research-claim-review-v0.1.schema.json",
  "title": "SD Prompt Studio Research Claim Review File",
  "description": "Append-only Claim Review and Review Withdrawal records for Research Claim Staging Layer v3.9.31.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_file_id", "reviews"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "review_file_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "reviews": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/reviewRecord" },
          { "$ref": "#/$defs/withdrawalRecord" }
        ]
      }
    }
  },
  "$defs": {
    "assertionId": {
      "type": "string",
      "pattern": "^assertion(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){2,}\\.[0-9]{3,}$"
    },
    "reviewId": {
      "type": "string",
      "pattern": "^review\\.assertion(?:\\.[a-z0-9]+(?:_[a-z0-9]+)*){2,}\\.[0-9]{3,}\\.[0-9]{3,}$"
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "reviewIdSet": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/reviewId" }
    },
    "reviewRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id", "assertion_id", "record_type", "decision", "reviewer",
        "recorded_at", "reviewed_assertion_hash", "hash_algorithm", "review_scope",
        "supersedes_review_ids"
      ],
      "properties": {
        "review_id": { "$ref": "#/$defs/reviewId" },
        "assertion_id": { "$ref": "#/$defs/assertionId" },
        "record_type": { "const": "review" },
        "decision": { "enum": ["approve", "reject", "needs_evidence"] },
        "reviewer": { "type": "string", "minLength": 1 },
        "recorded_at": { "$ref": "#/$defs/timestamp" },
        "reviewed_assertion_hash": { "$ref": "#/$defs/sha256" },
        "hash_algorithm": { "const": "sha256" },
        "review_scope": { "const": "assertion_content_v1" },
        "supersedes_review_ids": { "$ref": "#/$defs/reviewIdSet" },
        "notes": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "decision": { "enum": ["reject", "needs_evidence"] } },
            "required": ["decision"]
          },
          "then": { "required": ["notes"] }
        }
      ]
    },
    "withdrawalRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id", "assertion_id", "record_type", "withdrawn_at", "recorded_at",
        "supersedes_review_ids"
      ],
      "properties": {
        "review_id": { "$ref": "#/$defs/reviewId" },
        "assertion_id": { "$ref": "#/$defs/assertionId" },
        "record_type": { "const": "withdrawal" },
        "withdrawn_at": { "$ref": "#/$defs/timestamp" },
        "recorded_at": { "$ref": "#/$defs/timestamp" },
        "supersedes_review_ids": {
          "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/reviewId" }
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
