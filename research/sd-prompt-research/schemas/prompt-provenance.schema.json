{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.sd-prompt-studio/prompt-provenance-v0.1.schema.json",
  "x-contract-version": "0.1.0",
  "title": "SD Prompt Studio Prompt Provenance Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "content_identity",
    "provenance_generation"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "run_id": {"$ref": "#/$defs/runId"},
    "status": {"enum": ["available", "unavailable"]},
    "content_identity": {"$ref": "#/$defs/contentIdentity"},
    "provenance_generation": {"$ref": "#/$defs/provenanceGeneration"},
    "prompts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/promptEntry"}
    },
    "unavailable_reason": {"$ref": "#/$defs/unavailableReason"}
  },
  "allOf": [
    {
      "if": {
        "required": ["status"],
        "properties": {"status": {"const": "available"}}
      },
      "then": {
        "required": ["prompts"],
        "not": {"required": ["unavailable_reason"]}
      },
      "else": {
        "required": ["unavailable_reason"],
        "not": {"required": ["prompts"]}
      }
    }
  ],
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "runId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "contentIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "sha256"],
      "properties": {
        "contract": {"const": "prompt_provenance_content_v1"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "provenanceGeneration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "generator"],
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "generator": {"$ref": "#/$defs/generator"}
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["manual", "parser", "imported", "migration"]},
        "version": {"$ref": "#/$defs/semver"}
      },
      "allOf": [
        {
          "if": {
            "required": ["kind"],
            "properties": {"kind": {"const": "manual"}}
          },
          "then": {"not": {"required": ["version"]}},
          "else": {"required": ["version"]}
        }
      ]
    },
    "unavailableReason": {
      "enum": [
        "source_missing",
        "source_unresolvable",
        "source_not_string",
        "hash_verification_unavailable",
        "other"
      ]
    },
    "promptEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_channel",
        "prompt_stage",
        "effective_input_status",
        "source",
        "span_offset_unit",
        "extraction_coverage",
        "phrases"
      ],
      "properties": {
        "prompt_channel": {"enum": ["positive", "negative"]},
        "prompt_stage": {
          "enum": [
            "authored",
            "submitted",
            "embedded_generation_metadata",
            "manual_reconstruction"
          ]
        },
        "effective_input_status": {"enum": ["confirmed", "unconfirmed", "unknown"]},
        "source": {"$ref": "#/$defs/promptSource"},
        "span_offset_unit": {"const": "unicode_code_point"},
        "extraction_coverage": {"$ref": "#/$defs/extractionCoverage"},
        "phrases": {
          "type": "array",
          "items": {"$ref": "#/$defs/phraseOccurrence"}
        }
      }
    },
    "promptSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_artifact",
        "source_pointer",
        "source_kind",
        "source_prompt_hash",
        "hash_contract_version"
      ],
      "properties": {
        "source_artifact": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\\\r\\n]+$"
        },
        "source_pointer": {
          "type": "string",
          "pattern": "^/(?:[^~/]|~[01])*(?:/(?:[^~/]|~[01])*)*$"
        },
        "source_kind": {
          "enum": [
            "embedded_png_metadata",
            "manifest_prompt",
            "sidecar",
            "manual_reconstruction"
          ]
        },
        "source_prompt_hash": {"$ref": "#/$defs/sha256"},
        "hash_contract_version": {"const": "prompt_text_sha256_v1"}
      }
    },
    "extractionCoverage": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {"status": {"const": "complete"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "unparsed_spans"],
          "properties": {
            "status": {"const": "partial"},
            "unparsed_spans": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/unparsedSpan"}
            }
          }
        }
      ]
    },
    "unparsedSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "reason"],
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0},
        "reason": {
          "enum": [
            "unsupported_syntax",
            "ambiguous_boundary",
            "control_directive",
            "unresolved_embedding",
            "other"
          ]
        }
      }
    },
    "phraseOccurrence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phrase_occurrence_id",
        "text",
        "position",
        "source_span",
        "extraction_method",
        "primary_category",
        "category_candidates",
        "category_assignment_source",
        "category_confidence"
      ],
      "properties": {
        "phrase_occurrence_id": {
          "type": "string",
          "pattern": "^phrase\\.(positive|negative)\\.[0-9]{3}$"
        },
        "text": {"type": "string", "minLength": 1},
        "position": {"type": "integer", "minimum": 1},
        "source_span": {"$ref": "#/$defs/sourceSpan"},
        "extraction_method": {"$ref": "#/$defs/annotationMethod"},
        "primary_category": {"$ref": "#/$defs/category"},
        "category_candidates": {
          "type": "array",
          "items": {"$ref": "#/$defs/categoryCandidate"}
        },
        "category_assignment_source": {"$ref": "#/$defs/annotationMethod"},
        "category_confidence": {"$ref": "#/$defs/confidence"}
      }
    },
    "sourceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0}
      }
    },
    "annotationMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["manual", "deterministic_rule", "parser"]},
        "contract_version": {"$ref": "#/$defs/semver"}
      },
      "allOf": [
        {
          "if": {
            "required": ["kind"],
            "properties": {"kind": {"const": "manual"}}
          },
          "then": {"not": {"required": ["contract_version"]}},
          "else": {"required": ["contract_version"]}
        }
      ]
    },
    "categoryCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "confidence"],
      "properties": {
        "category": {"$ref": "#/$defs/category"},
        "confidence": {"$ref": "#/$defs/confidence"}
      }
    },
    "confidence": {
      "enum": ["high", "medium", "low", "unclear"]
    },
    "category": {
      "enum": [
        "character",
        "entity_identity",
        "hair",
        "face",
        "body_feature",
        "clothing",
        "pose",
        "support",
        "camera",
        "background",
        "environment",
        "object",
        "lighting",
        "style",
        "effect",
        "semantic_role",
        "unknown"
      ]
    }
  }
}
